# Copy to .env for local development (values match docker-compose.yml).
APP_ENVIRONMENT=local
APP_DATABASE_URL=postgresql+asyncpg://residential:residential@localhost:5432/residential

# Deployment-specific policy values (generic defaults shown; set the real ones per deployment).
APP_AUTH_RATE_LIMIT_ATTEMPTS=10
APP_AUTH_RATE_LIMIT_WINDOW_MINUTES=15
APP_CURRENCY=GTQ
APP_PARKING_SPOTS_PER_UNIT=2
APP_LOCAL_TIMEZONE=UTC
APP_VISIT_EXPIRATION_HOURS_OPTIONS=[1,2,4]
APP_VISIT_MAX_ADVANCE_DAYS=30
APP_VISIT_RECURRING_MAX_DAYS=366
APP_VISIT_LOG_RETENTION_DAYS=365
